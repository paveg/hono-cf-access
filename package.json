{
	"name": "hono-cf-access",
	"version": "0.4.0",
	"description": "Access control middleware for Hono leveraging Cloudflare Workers request.cf properties",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"sideEffects": false,
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"release": "pnpm build && changeset publish --no-git-tag",
		"version-packages": "changeset version && pnpm lint:fix"
	},
	"keywords": [
		"hono",
		"cloudflare",
		"workers",
		"middleware",
		"access-control",
		"geo-blocking",
		"country-block",
		"asn-block",
		"maintenance-mode"
	],
	"author": "paveg",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/paveg/hono-cf-access"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"engines": {
		"node": ">=20"
	},
	"peerDependencies": {
		"hono": ">=4.0.0"
	},
	"packageManager": "pnpm@10.14.0",
	"pnpm": {
		"onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "lefthook"]
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@changesets/changelog-github": "0.5.2",
		"@changesets/cli": "2.29.8",
		"@cloudflare/workers-types": "^4.0.0",
		"@vitest/coverage-v8": "^3.0.0",
		"hono": "^4.0.0",
		"lefthook": "2.1.2",
		"tsup": "^8.0.0",
		"typescript": "^5.6.0",
		"vitest": "^3.0.0"
	}
}
