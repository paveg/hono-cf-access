{
	"name": "hono-cf-access",
	"version": "0.5.0",
	"description": "Access control middleware for Hono leveraging Cloudflare Workers request.cf properties",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"sideEffects": false,
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test:compat": "tsc -p tsconfig.compat.json",
		"release": "pnpm build && changeset publish --no-git-tag",
		"version-packages": "changeset version && pnpm lint:fix"
	},
	"keywords": [
		"hono",
		"cloudflare",
		"workers",
		"middleware",
		"access-control",
		"geo-blocking",
		"country-block",
		"asn-block",
		"maintenance-mode"
	],
	"author": "paveg",
	"license": "MIT",
	"funding": "https://github.com/sponsors/paveg",
	"repository": {
		"type": "git",
		"url": "https://github.com/paveg/hono-cf-access"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"engines": {
		"node": ">=22"
	},
	"peerDependencies": {
		"hono": ">=4.0.0"
	},
	"packageManager": "pnpm@10.14.0",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"esbuild",
			"lefthook"
		],
		"overrides": {
			"vite@<6.4.2": "^6.4.2",
			"esbuild@<0.25.0": "^0.25.0",
			"picomatch@<2.3.2": "^2.3.2",
			"picomatch@>=4.0.0 <4.0.4": "^4.0.4",
			"postcss@<8.5.10": "^8.5.10"
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@changesets/changelog-github": "0.7.0",
		"@changesets/cli": "2.31.0",
		"@cloudflare/workers-types": "^4.0.0",
		"@vitest/coverage-v8": "^3.0.0",
		"hono": "^4.12.14",
		"lefthook": "2.1.6",
		"tsup": "^8.0.0",
		"typescript": "^6.0.3",
		"vitest": "^3.0.0"
	}
}
